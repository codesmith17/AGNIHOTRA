<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="2dp">

        <ImageView
            android:id="@+id/widget_logo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="@string/widget_logo_desc"
            android:layout_marginEnd="7dp" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_title"
            android:textColor="#FFF4D8"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:alpha="0.98" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_event_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="@string/widget_no_timing"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:textAlignment="center"
        android:textSize="21sp"
        android:textStyle="bold"
        android:maxLines="2" />

    <TextView
        android:id="@+id/widget_event_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="--"
        android:textColor="#FFF8D8"
        android:gravity="center"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_countdown_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/widget_countdown_title"
        android:textColor="#FFE5CF"
        android:gravity="center"
        android:textAlignment="center"
        android:textSize="13sp"
        android:textStyle="bold"
        android:alpha="0.95" />

    <TextView
        android:id="@+id/widget_countdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="--"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:textAlignment="center"
        android:textSize="25sp"
        android:textStyle="bold" />

    <Chronometer
        android:id="@+id/widget_countdown_chronometer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:textAlignment="center"
        android:textSize="25sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
